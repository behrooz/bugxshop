# Development Dockerfile with Go installed for hot-reload
FROM golang:1.21-alpine

WORKDIR /app

# Install air for hot-reload (optional but recommended)
RUN go install github.com/cosmtrek/air@latest

# Copy go mod files
COPY go.mod go.sum* ./

# Download dependencies
RUN go mod download

# Copy source code
COPY . .

# Expose port
EXPOSE 8080

# Use air for hot-reload, or just go run for simpler setup
CMD ["go", "run", "main.go"]

